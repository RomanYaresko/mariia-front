{
  "name": "mariia-front",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.config.dev.mts",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview --config vite.config.prod.mts",
    "build-only": "vite build --config vite.config.prod.mts",
    "type-check": "vue-tsc --build --force",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@vee-validate/zod": "^4.15.1",
    "axios": "^1.12.0",
    "dotenv": "^17.4.2",
    "pinia": "^3.0.3",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.11",
    "vue-router": "^4.6.3",
    "vue3-toastify": "^0.2.9",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.11",
    "@rushstack/eslint-patch": "^1.14.0",
    "@tsconfig/node20": "^20.1.6",
    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^9.30.0",
    "eslint-plugin-vue": "^10.4.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.6.2",
    "sass": "^1.89.2",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.9.2",
    "vite": "^8.1.0",
    "vite-plugin-vue-devtools": "^8.0.3",
    "vue-tsc": "^3.0.2"
  }
}
